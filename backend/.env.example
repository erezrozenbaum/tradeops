DATABASE_URL=postgresql://tradeops:tradeops@localhost:5432/tradeops
# Redis for distributed rate limiting (optional — falls back to in-memory if unset)
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me-in-production
ANTHROPIC_API_KEY=sk-ant-...
ALPHA_VANTAGE_API_KEY=your-key-here
ENVIRONMENT=development
DEBUG=true
WORKERS_ENABLED=true

# Email alerts (leave blank to disable — alerts are silently skipped when missing)
# Gmail example: use an App Password, not your main password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-address@gmail.com
SMTP_PASS=your-app-password
ALERT_FROM_EMAIL=noreply@tradeops.ai

# Langfuse — AI observability (optional; all AI calls are traced when set)
# Sign up at https://cloud.langfuse.com or run self-hosted via docker-compose
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# OpenTelemetry — OTLP exporter (optional; leave blank to disable trace export)
# Set to your collector endpoint, e.g. http://otel-collector:4317
OTEL_EXPORTER_OTLP_ENDPOINT=
